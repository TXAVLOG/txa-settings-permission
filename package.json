{
  "name": "txa-settings-permission",
  "version": "1.5.1",
  "type": "module",
  "description": "Capacitor plugin by TXA — Mở tất cả màn hình Settings cấp quyền trên Android, tự tương thích theo Android version",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/plugin.cjs.js"
    },
    "./file": {
      "types": "./dist/esm/file.d.ts",
      "import": "./dist/esm/file.js",
      "require": "./dist/cjs/file.js"
    }
  },
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "src/",
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "author": "TXA <txa@nrotxa.online>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TXAVLOG/txa-settings-permission.git"
  },
  "homepage": "https://github.com/TXAVLOG/txa-settings-permission",
  "bugs": {
    "url": "https://github.com/TXAVLOG/txa-settings-permission/issues"
  },
  "keywords": [
    "capacitor",
    "plugin",
    "android",
    "permission",
    "settings",
    "manage-external-storage",
    "overlay",
    "battery",
    "install-unknown",
    "notification",
    "accessibility",
    "txa",
    "txavlog"
  ],
  "scripts": {
    "build": "npm run clean && npm run compile",
    "clean": "rimraf ./dist",
    "compile": "npm run compile:esm && npm run compile:cjs && npm run compile:bundle",
    "compile:esm": "tsc --module es2020 --outDir ./dist/esm",
    "compile:cjs": "tsc --module commonjs --outDir ./dist/cjs",
    "compile:bundle": "rollup -c rollup.config.js",
    "verify:android": "cd android && ./gradlew clean build test && cd ..",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/check-capacitor.cjs"
  },
  "peerDependencies": {
    "@capacitor/core": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@capacitor/core": {
      "optional": false
    }
  },
  "devDependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "rimraf": "^5.0.0",
    "rollup": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "capacitor": {
    "android": {
      "src": "android"
    }
  },
  "engines": {
    "node": ">=16.0.0"
  }
}